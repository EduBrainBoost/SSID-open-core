{
  "api": {
    "name": "SSID Compliance Policy Validation API",
    "version": "1.0.0",
    "description": "API definition for AI/ML-driven compliance policy validation. Validates identity operations against applicable regulatory policies in real time."
  },
  "endpoints": [
    {
      "method": "POST",
      "path": "/v1/compliance/ai/validate-policy",
      "description": "Validate an operation against applicable compliance policies",
      "request": {
        "content_type": "application/json",
        "required_fields": {
          "operation_type": {
            "type": "string",
            "enum": ["kyc_verification", "identity_scoring", "data_export", "consent_update", "risk_assessment"]
          },
          "jurisdiction": {
            "type": "string",
            "pattern": "^[A-Z]{2}$"
          },
          "subject_hash": {
            "type": "string",
            "description": "SHA3-256 hash of the identity subject"
          },
          "parameters": {
            "type": "object",
            "description": "Operation-specific parameters for validation"
          }
        }
      },
      "response": {
        "status_200": {
          "fields": {
            "validation_id": "uuid",
            "result": "enum: compliant | non_compliant | requires_review",
            "applicable_policies": "array of policy_id strings",
            "violations": "array of violation objects",
            "confidence": "number 0.0 - 1.0",
            "model_version": "string",
            "validated_at": "ISO 8601 datetime"
          }
        },
        "status_400": "Invalid request payload",
        "status_401": "Unauthorized",
        "status_422": "Unsupported jurisdiction or operation type"
      }
    },
    {
      "method": "GET",
      "path": "/v1/compliance/ai/policies",
      "description": "List all active compliance policies",
      "parameters": {
        "jurisdiction": {
          "in": "query",
          "type": "string",
          "required": false
        },
        "category": {
          "in": "query",
          "type": "string",
          "required": false,
          "enum": ["privacy", "aml", "sanctions", "ai_act", "securities"]
        }
      },
      "response": {
        "status_200": {
          "fields": {
            "policies": "array of policy objects",
            "total_count": "integer"
          }
        }
      }
    },
    {
      "method": "GET",
      "path": "/v1/compliance/ai/validation/{validation_id}",
      "description": "Retrieve a specific validation result",
      "response": {
        "status_200": "Full validation result object",
        "status_404": "Validation not found"
      }
    }
  ],
  "authentication": {
    "type": "Bearer JWT",
    "required": true
  },
  "rate_limits": {
    "validate_policy": "100 requests per minute",
    "list_policies": "30 requests per minute"
  }
}
