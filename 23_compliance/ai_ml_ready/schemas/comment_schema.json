{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ssid.io/schemas/compliance/comment/v1",
  "title": "SSID Compliance Comment",
  "description": "Schema for compliance review comments used in AI/ML-assisted policy review workflows.",
  "type": "object",
  "required": ["comment_id", "author_hash", "target_type", "target_id", "body", "created_at"],
  "properties": {
    "comment_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the comment"
    },
    "author_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "SHA3-256 hash of the comment author identity (no PII)"
    },
    "author_role": {
      "type": "string",
      "enum": ["compliance_officer", "legal_counsel", "ai_system", "external_auditor", "technical_reviewer"],
      "description": "Role of the comment author"
    },
    "target_type": {
      "type": "string",
      "enum": ["policy", "validation_result", "audit_finding", "risk_assessment", "regulation_mapping"],
      "description": "Type of artefact this comment is attached to"
    },
    "target_id": {
      "type": "string",
      "description": "Identifier of the target artefact"
    },
    "body": {
      "type": "string",
      "minLength": 1,
      "maxLength": 10000,
      "description": "Comment text content"
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"],
      "description": "Severity classification of the comment"
    },
    "action_required": {
      "type": "boolean",
      "default": false,
      "description": "Whether this comment requires follow-up action"
    },
    "resolution_status": {
      "type": "string",
      "enum": ["open", "acknowledged", "in_progress", "resolved", "wont_fix"],
      "default": "open"
    },
    "parent_comment_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Parent comment ID for threaded discussions"
    },
    "ai_generated": {
      "type": "boolean",
      "default": false,
      "description": "Whether this comment was generated by an AI system"
    },
    "ai_confidence": {
      "type": ["number", "null"],
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "AI confidence score if ai_generated is true"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": ["string", "null"],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
