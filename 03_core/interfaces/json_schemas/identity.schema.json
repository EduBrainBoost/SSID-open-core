{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ssid.network/schemas/v4/identity.schema.json",
  "title": "Identity",
  "description": "A Self-Sovereign Identity (SSI) participant record in the SSID network.",
  "type": "object",
  "required": ["id", "display_name", "public_key_multibase", "key_type", "verification_level", "status", "created_at", "updated_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^did:ssid:[a-zA-Z0-9]+$",
      "description": "Decentralized Identifier (DID) — globally unique identity anchor.",
      "examples": ["did:ssid:z6Mkk7yqnGF3YwTGjthmMNymUWz5t6BPTMFrMUCDFCCR"]
    },
    "display_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Human-readable display name for the identity.",
      "examples": ["Alice Wonderland"]
    },
    "public_key_multibase": {
      "type": "string",
      "description": "Multibase-encoded public key associated with this identity.",
      "examples": ["zH3C2AVvLMv6gmMNam3uVAjZpfkcJCwDwnZn6z3wXmqPV"]
    },
    "key_type": {
      "type": "string",
      "enum": ["Ed25519VerificationKey2020", "JsonWebKey2020"],
      "description": "Cryptographic key type per W3C VC Data Integrity spec.",
      "examples": ["Ed25519VerificationKey2020"]
    },
    "verification_level": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4,
      "description": "Highest achieved verification level: 0=unverified, 1=email, 2=phone, 3=document, 4=biometric.",
      "examples": [3]
    },
    "status": {
      "type": "string",
      "enum": ["active", "deactivated", "suspended"],
      "description": "Current lifecycle status of the identity.",
      "examples": ["active"]
    },
    "controller": {
      "type": "string",
      "pattern": "^did:ssid:[a-zA-Z0-9]+$",
      "description": "Optional DID of the controller (defaults to self-controlled).",
      "examples": ["did:ssid:z6Mkk7yqnGF3YwTGjthmMNymUWz5t6BPTMFrMUCDFCCR"]
    },
    "metadata": {
      "type": "object",
      "description": "Arbitrary key-value metadata attached to the identity. PII must be hashed.",
      "additionalProperties": true,
      "examples": [
        {
          "email_hash": "sha256:5d41402abc4b2a76b9719d911017c592",
          "country_code": "DE"
        }
      ]
    },
    "service_endpoints": {
      "type": "array",
      "description": "DID Document service endpoints.",
      "items": {
        "type": "object",
        "required": ["id", "type", "serviceEndpoint"],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "serviceEndpoint": {
            "oneOf": [
              {"type": "string", "format": "uri"},
              {"type": "array", "items": {"type": "string", "format": "uri"}}
            ]
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the identity was created.",
      "examples": ["2026-03-15T10:00:00Z"]
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the last update.",
      "examples": ["2026-03-15T10:00:00Z"]
    },
    "deactivated_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "ISO 8601 timestamp when the identity was deactivated, null if still active.",
      "examples": [null]
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "id": "did:ssid:z6Mkk7yqnGF3YwTGjthmMNymUWz5t6BPTMFrMUCDFCCR",
      "display_name": "Alice Wonderland",
      "public_key_multibase": "zH3C2AVvLMv6gmMNam3uVAjZpfkcJCwDwnZn6z3wXmqPV",
      "key_type": "Ed25519VerificationKey2020",
      "verification_level": 3,
      "status": "active",
      "controller": "did:ssid:z6Mkk7yqnGF3YwTGjthmMNymUWz5t6BPTMFrMUCDFCCR",
      "metadata": {
        "email_hash": "sha256:5d41402abc4b2a76b9719d911017c592",
        "country_code": "DE"
      },
      "service_endpoints": [
        {
          "id": "did:ssid:z6Mkk7yqnGF3YwTGjthmMNymUWz5t6BPTMFrMUCDFCCR#messaging",
          "type": "DIDCommMessaging",
          "serviceEndpoint": "https://agent.alice.example.com/didcomm"
        }
      ],
      "created_at": "2026-03-15T10:00:00Z",
      "updated_at": "2026-03-15T10:00:00Z",
      "deactivated_at": null
    }
  ]
}
