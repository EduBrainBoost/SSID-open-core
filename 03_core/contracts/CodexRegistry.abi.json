[
  {
    "type": "constructor",
    "inputs": [
      { "name": "initialOwner", "type": "address", "internalType": "address" }
    ],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "owner",
    "inputs": [],
    "outputs": [{ "name": "", "type": "address", "internalType": "address" }],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "transferOwnership",
    "inputs": [
      { "name": "newOwner", "type": "address", "internalType": "address" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "addRegistrar",
    "inputs": [
      { "name": "registrar", "type": "address", "internalType": "address" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "removeRegistrar",
    "inputs": [
      { "name": "registrar", "type": "address", "internalType": "address" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "isRegistrar",
    "inputs": [
      { "name": "", "type": "address", "internalType": "address" }
    ],
    "outputs": [{ "name": "", "type": "bool", "internalType": "bool" }],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "register",
    "inputs": [
      { "name": "shardId",     "type": "bytes32", "internalType": "bytes32" },
      { "name": "contentHash", "type": "bytes32", "internalType": "bytes32" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "update",
    "inputs": [
      { "name": "shardId",        "type": "bytes32", "internalType": "bytes32" },
      { "name": "newContentHash", "type": "bytes32", "internalType": "bytes32" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "revoke",
    "inputs": [
      { "name": "shardId", "type": "bytes32", "internalType": "bytes32" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "getEntry",
    "inputs": [
      { "name": "shardId", "type": "bytes32", "internalType": "bytes32" }
    ],
    "outputs": [
      {
        "name": "entry",
        "type": "tuple",
        "internalType": "struct CodexRegistry.CodexEntry",
        "components": [
          { "name": "contentHash",  "type": "bytes32", "internalType": "bytes32" },
          { "name": "registrar",    "type": "address", "internalType": "address" },
          { "name": "registeredAt", "type": "uint64",  "internalType": "uint64"  },
          { "name": "updatedAt",    "type": "uint64",  "internalType": "uint64"  },
          { "name": "status",       "type": "uint8",   "internalType": "enum CodexRegistry.EntryStatus" }
        ]
      }
    ],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "isActive",
    "inputs": [
      { "name": "shardId", "type": "bytes32", "internalType": "bytes32" }
    ],
    "outputs": [{ "name": "active", "type": "bool", "internalType": "bool" }],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "getContentHash",
    "inputs": [
      { "name": "shardId", "type": "bytes32", "internalType": "bytes32" }
    ],
    "outputs": [{ "name": "contentHash", "type": "bytes32", "internalType": "bytes32" }],
    "stateMutability": "view"
  },
  {
    "type": "event",
    "name": "Registered",
    "inputs": [
      { "name": "shardId",     "type": "bytes32", "indexed": true  },
      { "name": "contentHash", "type": "bytes32", "indexed": true  },
      { "name": "registrar",   "type": "address", "indexed": true  }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "Updated",
    "inputs": [
      { "name": "shardId",        "type": "bytes32", "indexed": true  },
      { "name": "oldContentHash", "type": "bytes32", "indexed": false },
      { "name": "newContentHash", "type": "bytes32", "indexed": true  },
      { "name": "registrar",      "type": "address", "indexed": true  }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "Revoked",
    "inputs": [
      { "name": "shardId",   "type": "bytes32", "indexed": true },
      { "name": "registrar", "type": "address", "indexed": true }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "RegistrarAdded",
    "inputs": [
      { "name": "registrar", "type": "address", "indexed": true }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "RegistrarRemoved",
    "inputs": [
      { "name": "registrar", "type": "address", "indexed": true }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "OwnershipTransferred",
    "inputs": [
      { "name": "previousOwner", "type": "address", "indexed": true },
      { "name": "newOwner",      "type": "address", "indexed": true }
    ],
    "anonymous": false
  },
  { "type": "error", "name": "Unauthorized",      "inputs": [] },
  { "type": "error", "name": "AlreadyRegistered", "inputs": [{ "name": "shardId", "type": "bytes32" }] },
  { "type": "error", "name": "NotRegistered",     "inputs": [{ "name": "shardId", "type": "bytes32" }] },
  { "type": "error", "name": "AlreadyRevoked",    "inputs": [{ "name": "shardId", "type": "bytes32" }] },
  { "type": "error", "name": "ZeroAddress",       "inputs": [] },
  { "type": "error", "name": "EmptyContentHash",  "inputs": [] }
]
