{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ssid.dev/sws/schemas/transcript_master.schema.json",
  "title": "SWS Transcript Master",
  "description": "Full transcript output from the speech-to-text pipeline with per-segment confidence.",
  "type": "object",
  "required": ["transcript_id", "language", "segments", "full_text"],
  "properties": {
    "transcript_id": {
      "type": "string",
      "description": "Unique identifier for this transcript."
    },
    "language": {
      "type": "string",
      "minLength": 2,
      "maxLength": 10,
      "description": "BCP-47 language tag (e.g. en, de, en-US)."
    },
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["segment_id", "start_time", "end_time", "text", "confidence"],
        "properties": {
          "segment_id": {
            "type": "integer",
            "minimum": 1,
            "description": "1-based segment index."
          },
          "start_time": {
            "type": "number",
            "minimum": 0,
            "description": "Segment start time in seconds."
          },
          "end_time": {
            "type": "number",
            "minimum": 0,
            "description": "Segment end time in seconds."
          },
          "text": {
            "type": "string",
            "description": "Transcribed text for this segment."
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Confidence score [0..1]."
          }
        },
        "additionalProperties": false
      },
      "description": "Ordered list of transcript segments."
    },
    "full_text": {
      "type": "string",
      "description": "Concatenated full transcript text."
    }
  },
  "additionalProperties": false
}
