{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ssid.dev/schemas/sws/v1.5/rebuild_timeline.schema.json",
  "title": "SWS Rebuild Timeline",
  "description": "Final timeline consumed by the Render Engine. One track per modality.",
  "type": "object",
  "required": ["timeline_id", "job_id", "blueprint_id", "plan_id", "created_at", "fps", "total_duration_ms", "tracks"],
  "additionalProperties": false,
  "properties": {
    "timeline_id": {"type": "string", "pattern": "^tl_[A-Za-z0-9]{8,}$"},
    "job_id": {"type": "string"},
    "blueprint_id": {"type": "string"},
    "plan_id": {"type": "string"},
    "created_at": {"type": "string", "format": "date-time"},
    "fps": {"type": "number", "minimum": 0},
    "total_duration_ms": {"type": "integer", "minimum": 0},
    "tracks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["track_id", "kind", "clips"],
        "properties": {
          "track_id": {"type": "string"},
          "kind": {"type": "string", "enum": ["video", "audio_voice", "audio_music", "audio_sfx", "caption_overlay", "graphic_overlay"]},
          "clips": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["clip_index", "start_ms", "end_ms", "asset_ref"],
              "properties": {
                "clip_index": {"type": "integer", "minimum": 0},
                "start_ms": {"type": "integer", "minimum": 0},
                "end_ms": {"type": "integer", "minimum": 0},
                "asset_ref": {"type": "string"},
                "in_point_ms": {"type": "integer", "minimum": 0},
                "out_point_ms": {"type": "integer", "minimum": 0},
                "volume": {"type": "number", "minimum": 0, "maximum": 2},
                "text": {"type": "string"},
                "style_ref": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
