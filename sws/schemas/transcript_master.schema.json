{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ssid.dev/schemas/sws/v1/transcript_master.schema.json",
  "title": "SWS Transcript Master",
  "description": "Word-aligned ASR output with optional speaker diarization. One record per source.",
  "type": "object",
  "required": ["job_id", "source_sha256", "asr_engine", "language", "created_at", "segments"],
  "additionalProperties": false,
  "properties": {
    "job_id": {"type": "string"},
    "source_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "asr_engine": {"type": "string", "description": "e.g. whisper-v3, whisperx"},
    "language": {"type": "string", "description": "BCP-47 or ISO-639-1"},
    "language_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "segments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["index", "start_ms", "end_ms", "text"],
        "properties": {
          "index": {"type": "integer", "minimum": 0},
          "start_ms": {"type": "integer", "minimum": 0},
          "end_ms": {"type": "integer", "minimum": 0},
          "text": {"type": "string"},
          "speaker": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "words": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["w", "start_ms", "end_ms"],
              "properties": {
                "w": {"type": "string"},
                "start_ms": {"type": "integer", "minimum": 0},
                "end_ms": {"type": "integer", "minimum": 0},
                "confidence": {"type": "number", "minimum": 0, "maximum": 1}
              }
            }
          }
        }
      }
    }
  }
}
