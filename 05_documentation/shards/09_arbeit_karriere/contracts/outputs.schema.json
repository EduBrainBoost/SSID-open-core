{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "result_id",
    "status"
  ],
  "properties": {
    "result_id": {
      "type": "string",
      "minLength": 8
    },
    "status": {
      "type": "string",
      "enum": [
        "accepted",
        "rejected"
      ]
    }
  },
  "additionalProperties": false
}
