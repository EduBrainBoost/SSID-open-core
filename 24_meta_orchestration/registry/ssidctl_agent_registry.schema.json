{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ssidctl_agent_registry.schema.json",
  "title": "SSIDCTL Agent Registry Schema v2",
  "description": "JSON Schema fuer die operative SSIDCTL 87-Agent Registry",
  "type": "object",
  "required": ["schema_version", "generated", "description", "total_agents", "layer_counts", "global_rules", "agents"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "generated": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "legacy_system_ref": {
      "type": "string"
    },
    "legacy_mapping_ref": {
      "type": "string"
    },
    "total_agents": {
      "type": "integer",
      "const": 87
    },
    "layer_counts": {
      "type": "object",
      "required": ["L0", "L1", "L2", "L3", "L4", "L5"],
      "properties": {
        "L0": { "type": "integer", "const": 1 },
        "L1": { "type": "integer", "const": 5 },
        "L2": { "type": "integer", "const": 24 },
        "L3": { "type": "integer", "const": 16 },
        "L4": { "type": "integer", "const": 24 },
        "L5": { "type": "integer", "const": 17 }
      },
      "additionalProperties": false
    },
    "global_rules": {
      "type": "object",
      "required": ["workspace_root", "canonical_reference_only", "canonical_write", "mode", "allowed_repo_scope", "forbidden_global"],
      "properties": {
        "workspace_root": { "type": "string" },
        "canonical_reference_only": { "type": "string" },
        "canonical_write": { "type": "boolean", "const": false },
        "mode": {
          "type": "array",
          "items": { "type": "string", "enum": ["LOCAL_FIRST", "SAFE_FIX", "ROOT_24_LOCK", "NON_INTERACTIVE"] },
          "minItems": 4
        },
        "allowed_repo_scope": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 5
        },
        "forbidden_global": {
          "type": "array",
          "items": { "type": "string" }
        },
        "coordination_rule": { "type": "string" },
        "evidence_rule": { "type": "string" },
        "path_rule": { "type": "string" }
      }
    },
    "agents": {
      "type": "array",
      "minItems": 87,
      "maxItems": 87,
      "items": {
        "$ref": "#/$defs/agent"
      }
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": [
        "agent_id", "status", "level", "repo_scope", "root_scope", "shard_scope",
        "purpose", "skills", "allowed_paths", "forbidden_paths",
        "inputs", "outputs", "done_criteria", "activation_conditions",
        "depends_on", "writes_allowed", "can_touch_canonical", "risk_class"
      ],
      "properties": {
        "agent_id": {
          "type": "string",
          "pattern": "^ssidctl\\.l[0-5]\\."
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive", "deprecated", "planned"]
        },
        "level": {
          "type": "string",
          "enum": ["L0", "L1", "L2", "L3", "L4", "L5"]
        },
        "repo_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["SSID", "SSID-EMS", "SSID-orchestrator", "SSID-open-core", "SSID-docs"]
          }
        },
        "root_scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "shard_scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "purpose": { "type": "string" },
        "skills": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "allowed_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_paths": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "done_criteria": { "type": "string" },
        "activation_conditions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "writes_allowed": { "type": "boolean" },
        "can_touch_canonical": { "type": "boolean", "const": false },
        "risk_class": {
          "type": "string",
          "enum": [
            "governance", "repo-control",
            "root-owner", "root-owner-critical",
            "shard-owner", "shard-owner-sensitive", "shard-owner-critical",
            "platform", "platform-critical",
            "product", "product-critical"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
