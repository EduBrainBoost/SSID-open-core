{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SSID Dispatcher Task Spec",
  "type": "object",
  "required": [
    "task_id",
    "scope",
    "allowed_paths",
    "expected_artifacts",
    "acceptance_checks",
    "agent_roles",
    "patch_strategy",
    "log_mode",
    "prompt"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "scope": {
      "type": "object",
      "required": ["roots", "shards", "paths"],
      "properties": {
        "roots": {
          "type": "array",
          "items": {"type": "string"}
        },
        "shards": {
          "type": "array",
          "items": {"type": "string"}
        },
        "paths": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    },
    "allowed_paths": {
      "type": "array",
      "items": {"type": "string"}
    },
    "expected_artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "acceptance_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "write_gate",
          "policy_gate",
          "sot_gate",
          "qa_master_suite",
          "ci_gate_mirror"
        ]
      }
    },
    "agent_roles": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "Planner",
          "Implementer",
          "ComplianceAuditor",
          "TestRunner",
          "ReleaseIntegrator"
        ]
      }
    },
    "patch_strategy": {
      "type": "string",
      "enum": ["single-commit", "no-rewrites"]
    },
    "log_mode": {
      "type": "string",
      "enum": ["MINIMAL", "FORENSIC"]
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
