{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SSID EMS Identities",
  "description": "Maps local usernames to RBAC roles for ssidctl CLI. No secrets, no tokens.",
  "type": "object",
  "required": ["identities"],
  "properties": {
    "identities": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["role"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["owner", "admin", "reviewer", "contributor", "readonly"]
          },
          "display_name": {
            "type": "string",
            "description": "Optional human-readable name"
          }
        },
        "additionalProperties": false
      },
      "minProperties": 1,
      "description": "Map of username -> role definition"
    },
    "default_role": {
      "type": "string",
      "enum": ["readonly", "contributor"],
      "default": "readonly",
      "description": "Role for unknown usernames. Must be low-privilege."
    }
  },
  "additionalProperties": false
}
