{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReportBusEvent",
  "description": "Backfill event record for report_bus",
  "type": "object",
  "required": ["kind", "repo", "severity", "sha", "source", "summary", "ts_utc"],
  "properties": {
    "kind": {
      "type": "string"
    },
    "repo": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["info", "warn", "error"]
    },
    "sha": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "ts_utc": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
