{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SoT Baseline Snapshot",
  "description": "Canonical SoT baseline snapshot for SSID governance enforcement",
  "type": "object",
  "required": ["snapshot_id", "created_at_utc", "baseline_version", "scope", "artifact_count", "artifacts", "evidence_hash", "generator"],
  "properties": {
    "snapshot_id": {"type": "string", "pattern": "^BL-"},
    "created_at_utc": {"type": "string", "format": "date-time"},
    "baseline_version": {"type": "string"},
    "scope": {"type": "string", "const": "canonical_sot"},
    "artifact_count": {"type": "integer", "minimum": 1},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "path", "sha256"],
        "properties": {
          "artifact_id": {"type": "string"},
          "path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "version": {"type": ["string", "null"]},
          "rule_count": {"type": ["integer", "null"]}
        }
      }
    },
    "evidence_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "generator": {"type": "string"}
  },
  "additionalProperties": false
}
