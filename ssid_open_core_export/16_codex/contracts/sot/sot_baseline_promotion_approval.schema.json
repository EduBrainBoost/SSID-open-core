{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SoT Baseline Promotion Approval",
  "type": "object",
  "required": [
    "approval_id",
    "created_at_utc",
    "approved_by",
    "reason",
    "source_convergence_report",
    "source_convergence_evidence_hash",
    "source_baseline_snapshot",
    "target_baseline_version",
    "approval_scope",
    "decision",
    "evidence_ref"
  ],
  "properties": {
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "approved_by": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "source_convergence_report": {
      "type": "string",
      "minLength": 1
    },
    "source_convergence_evidence_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "source_baseline_snapshot": {
      "type": "string",
      "minLength": 1
    },
    "target_baseline_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "approval_scope": {
      "type": "string",
      "enum": [
        "canonical_sot",
        "full_canonical_sot"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "reject"
      ]
    },
    "evidence_ref": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
