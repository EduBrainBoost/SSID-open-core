{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ExecutionIndex",
  "description": "Canonical mapping: TaskSpec -> PR -> MergeSHA -> Evidence/Event",
  "type": "object",
  "required": ["version", "repo", "entries"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "repo": {
      "type": "string"
    },
    "generated_utc": {
      "type": "string",
      "format": "date-time"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["merge_sha", "commit_date_utc", "subject"],
        "properties": {
          "merge_sha": { "type": "string" },
          "commit_date_utc": { "type": "string", "format": "date-time" },
          "subject": { "type": "string" },
          "pr_number": { "type": ["integer", "null"] },
          "task_id": { "type": ["string", "null"] },
          "has_agent_run": { "type": "boolean" },
          "has_report_event": { "type": "boolean" },
          "agent_run_path": { "type": ["string", "null"] },
          "report_event_path": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
