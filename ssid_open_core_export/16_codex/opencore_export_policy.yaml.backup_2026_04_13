# SSID Open-Core Export Policy v2.0.0
# Authoritative source: SSID private repo (this file)
# Defines what MAY and what MUST NOT be mirrored to SSID-open-core
---
schema_version: "2.0.0"
source_repo: "SSID"
target_repo: "SSID-open-core"
mode: "filtered"

# All 24 canonical roots are allowed in open-core (Root-24 scaffolding)
allow_prefixes:
  - "01_ai_layer/"
  - "02_audit_logging/"
  - "03_core/"
  - "04_deployment/"
  - "05_documentation/"
  - "06_data_pipeline/"
  - "07_governance_legal/"
  - "08_identity_score/"
  - "09_meta_identity/"
  - "10_interoperability/"
  - "11_test_simulation/"
  - "12_tooling/"
  - "13_ui_layer/"
  - "14_zero_time_auth/"
  - "15_infra/"
  - "16_codex/"
  - "17_observability/"
  - "18_data_layer/"
  - "19_adapters/"
  - "20_foundation/"
  - "21_post_quantum_crypto/"
  - "22_datasets/"
  - "23_compliance/"
  - "24_meta_orchestration/"
  # Top-level files
  - "LICENSE"
  - "README.md"
  - "CONTRIBUTING.md"
  - "AGENTS.md"
  - "pytest.ini"
  - "pyproject.toml"

# Allowed file extensions in open-core exports
allow_extensions:
  - ".py"
  - ".yaml"
  - ".yml"
  - ".md"
  - ".toml"
  - ".cfg"
  - ".ini"
  - ".txt"
  - ".json"
  - ".sol"

# Maximum file size for export (10 MB)
max_file_size_bytes: 10485760

# Glob patterns that must never be exported
deny_globs:
  - "**/.env"
  - "**/.env.*"
  - "**/secrets/**"
  - "**/credentials/**"
  - "**/private/**"
  - "**/*.pem"
  - "**/*.key"
  - "**/*.p12"
  - "02_audit_logging/storage/**"
  - "02_audit_logging/evidence/**"
  - "24_meta_orchestration/registry/logs/**"
  - "security/results/**"
  - "**/__pycache__/**"
  - "**/node_modules/**"

# Secret patterns to scan before export
secret_scan_regex:
  - "BEGIN (RSA|OPENSSH|EC) PRIVATE KEY"
  - "AKIA[0-9A-Z]{16}"
  - "xox[baprs]-"
  - "ghp_[A-Za-z0-9]{36}"
  - "-----BEGIN PRIVATE KEY-----"
  - "sk-[A-Za-z0-9]{48}"
  - "glpat-[A-Za-z0-9]{20}"

# Enforcement
enforcement:
  ci_gate_required: true
  pre_export_scan: true
  fail_on_deny_match: true
  fail_on_secret_match: true

# Export manifest schema for validation
export_manifest_schema:
  required_fields:
    - "export_id"
    - "timestamp"
    - "source_commit"
    - "files"
    - "policy_version"
  format: "json"

# Status note
note: >
  As of 2026-04-05, all 24 canonical roots are scaffolded in open-core.
  Sensitive data (storage, evidence, secrets) is protected via deny_globs.
  This policy is the authoritative SoT for the export boundary.
