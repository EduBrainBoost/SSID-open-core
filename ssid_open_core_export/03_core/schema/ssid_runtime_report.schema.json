{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SsidRuntimeReport",
  "description": "SSID-to-EMS runtime status report schema v1.0.0",
  "type": "object",
  "required": ["schema_version", "generated_at", "module_health", "flow_statuses"],
  "properties": {
    "schema_version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "generated_at": {"type": "string", "format": "date-time"},
    "module_health": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["module_name", "status", "version", "last_checked_utc"],
        "properties": {
          "module_name": {"type": "string"},
          "status": {"type": "string", "enum": ["healthy", "degraded", "offline"]},
          "version": {"type": "string"},
          "last_checked_utc": {"type": "string"}
        }
      }
    },
    "flow_statuses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["flow_name", "status"],
        "properties": {
          "flow_id": {"type": "string"},
          "flow_name": {"type": "string"},
          "status": {"type": "string", "enum": ["success", "denied", "error", "degraded"]},
          "allow_or_deny": {"type": "string", "enum": ["allow", "deny"]},
          "input_hash": {"type": "string"},
          "output_hash": {"type": "string"},
          "proof_hash": {"type": ["string", "null"]},
          "determinism_hash": {"type": "string"},
          "policy_decisions": {"type": "array", "items": {"type": "object"}},
          "timestamp_utc": {"type": "string"},
          "schema_version": {"type": "string"}
        }
      }
    }
  }
}
