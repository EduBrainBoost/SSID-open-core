{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ssid.network/schemas/v4/fee_distribution.schema.json",
  "title": "FeeDistribution",
  "description": "Result of a single fee distribution run across SSID network participants. Corresponds to DistributionResult from 03_core/fee_distribution_engine.py.",
  "type": "object",
  "required": ["epoch", "total_fee", "allocations", "residual", "distributed_at", "participant_count"],
  "properties": {
    "epoch": {
      "type": "string",
      "pattern": "^epoch-[0-9]{4}-[0-9]{2}$",
      "description": "Epoch identifier in format epoch-YYYY-MM.",
      "examples": ["epoch-2026-03"]
    },
    "total_fee": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]{1,6})?$",
      "description": "Total fee amount distributed (decimal string to preserve precision).",
      "examples": ["10000.000000"]
    },
    "allocations": {
      "type": "array",
      "description": "Per-participant fee allocations.",
      "items": {
        "$ref": "#/$defs/AllocationEntry"
      },
      "minItems": 1
    },
    "residual": {
      "type": "string",
      "pattern": "^[0-9]+(\\.[0-9]{1,6})?$",
      "description": "Unallocated remainder due to rounding (should be near zero).",
      "examples": ["0.000004"]
    },
    "role_summary": {
      "type": "object",
      "description": "Aggregated allocation totals per role.",
      "properties": {
        "validator": {"type": "string"},
        "provider": {"type": "string"},
        "consumer": {"type": "string"},
        "governance": {"type": "string"},
        "reserve": {"type": "string"}
      },
      "additionalProperties": false
    },
    "fairness": {
      "type": "object",
      "description": "Embedded fairness evaluation snapshot.",
      "properties": {
        "gini_coefficient": {
          "type": "number",
          "format": "double",
          "minimum": 0,
          "maximum": 1,
          "description": "Gini coefficient of this distribution (0=perfect equality, 1=maximum inequality).",
          "examples": [0.182]
        },
        "is_fair": {
          "type": "boolean",
          "description": "True when all FairnessConstraint checks passed.",
          "examples": [true]
        },
        "violations": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of fairness violation messages, empty when is_fair=true."
        }
      },
      "required": ["gini_coefficient", "is_fair", "violations"]
    },
    "role_weights_used": {
      "type": "object",
      "description": "Role weight configuration in effect for this epoch.",
      "properties": {
        "validator": {"type": "number", "format": "double"},
        "provider": {"type": "number", "format": "double"},
        "consumer": {"type": "number", "format": "double"},
        "governance": {"type": "number", "format": "double"},
        "reserve": {"type": "number", "format": "double"}
      },
      "additionalProperties": false,
      "examples": [
        {
          "validator": 0.40,
          "provider": 0.30,
          "consumer": 0.10,
          "governance": 0.10,
          "reserve": 0.10
        }
      ]
    },
    "participant_count": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of participants included in this distribution.",
      "examples": [47]
    },
    "distributed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the distribution was computed.",
      "examples": ["2026-03-31T23:59:59Z"]
    }
  },
  "$defs": {
    "AllocationEntry": {
      "type": "object",
      "required": ["participant_id", "role", "contribution_score", "allocated_amount"],
      "properties": {
        "participant_id": {
          "type": "string",
          "description": "Unique participant identifier.",
          "examples": ["did:ssid:z6Mkk7yqnGF3YwTGjthmMNymUWz5t6BPTMFrMUCDFCCR"]
        },
        "role": {
          "type": "string",
          "enum": ["validator", "provider", "consumer", "governance", "reserve"],
          "description": "Participant role determining base weight.",
          "examples": ["validator"]
        },
        "contribution_score": {
          "type": "number",
          "format": "double",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Normalised contribution score in [0, 1].",
          "examples": [0.92]
        },
        "allocated_amount": {
          "type": "string",
          "pattern": "^[0-9]+(\\.[0-9]{1,6})?$",
          "description": "Allocated fee amount (decimal string).",
          "examples": ["384.000000"]
        },
        "address": {
          "type": ["string", "null"],
          "description": "Settlement address or account reference.",
          "examples": ["0xAbCdEf1234567890AbCdEf1234567890AbCdEf12"]
        }
      }
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "epoch": "epoch-2026-03",
      "total_fee": "10000.000000",
      "allocations": [
        {
          "participant_id": "did:ssid:z6Mkk7yqnGF3YwTGjthmMNymUWz5t6BPTMFrMUCDFCCR",
          "role": "validator",
          "contribution_score": 0.92,
          "allocated_amount": "384.000000",
          "address": "0xAbCdEf1234567890AbCdEf1234567890AbCdEf12"
        },
        {
          "participant_id": "did:ssid:z6MkProvider1AbCdEfGhIjKlMnOpQrStUvWxYz",
          "role": "provider",
          "contribution_score": 0.75,
          "allocated_amount": "225.000000",
          "address": null
        }
      ],
      "residual": "0.000004",
      "role_summary": {
        "validator": "4000.000000",
        "provider": "3000.000000",
        "consumer": "1000.000000",
        "governance": "1000.000000",
        "reserve": "1000.000000"
      },
      "fairness": {
        "gini_coefficient": 0.182,
        "is_fair": true,
        "violations": []
      },
      "role_weights_used": {
        "validator": 0.40,
        "provider": 0.30,
        "consumer": 0.10,
        "governance": 0.10,
        "reserve": 0.10
      },
      "participant_count": 47,
      "distributed_at": "2026-03-31T23:59:59Z"
    }
  ]
}
