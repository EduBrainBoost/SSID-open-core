[
  {
    "type": "constructor",
    "inputs": [
      { "name": "initialOwner", "type": "address", "internalType": "address" }
    ],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "owner",
    "inputs": [],
    "outputs": [{ "name": "", "type": "address", "internalType": "address" }],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "transferOwnership",
    "inputs": [{ "name": "newOwner", "type": "address", "internalType": "address" }],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "registerValidator",
    "inputs": [
      { "name": "validator", "type": "address", "internalType": "address" },
      { "name": "metaURI",   "type": "string",  "internalType": "string"  }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "deregisterValidator",
    "inputs": [
      { "name": "validator", "type": "address", "internalType": "address" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "isValidatorRegistered",
    "inputs": [
      { "name": "validator", "type": "address", "internalType": "address" }
    ],
    "outputs": [{ "name": "registered", "type": "bool", "internalType": "bool" }],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "validatorMeta",
    "inputs": [{ "name": "", "type": "address", "internalType": "address" }],
    "outputs": [{ "name": "", "type": "string", "internalType": "string" }],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "setFeeSchedule",
    "inputs": [
      { "name": "verificationType", "type": "bytes32", "internalType": "bytes32" },
      { "name": "feeWei",           "type": "uint256", "internalType": "uint256" },
      { "name": "validator",        "type": "address", "internalType": "address" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "deactivateFeeSchedule",
    "inputs": [
      { "name": "verificationType", "type": "bytes32", "internalType": "bytes32" }
    ],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "function",
    "name": "feeSchedules",
    "inputs": [{ "name": "", "type": "bytes32", "internalType": "bytes32" }],
    "outputs": [
      { "name": "feeWei",    "type": "uint256", "internalType": "uint256" },
      { "name": "validator", "type": "address", "internalType": "address" },
      { "name": "active",    "type": "bool",    "internalType": "bool"    }
    ],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "routeFee",
    "inputs": [
      { "name": "verificationType", "type": "bytes32", "internalType": "bytes32" }
    ],
    "outputs": [],
    "stateMutability": "payable"
  },
  {
    "type": "function",
    "name": "pendingWithdrawal",
    "inputs": [{ "name": "", "type": "address", "internalType": "address" }],
    "outputs": [{ "name": "", "type": "uint256", "internalType": "uint256" }],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "withdraw",
    "inputs": [],
    "outputs": [],
    "stateMutability": "nonpayable"
  },
  {
    "type": "receive",
    "stateMutability": "payable"
  },
  {
    "type": "event",
    "name": "FeeRouted",
    "inputs": [
      { "name": "verificationType", "type": "bytes32", "indexed": true  },
      { "name": "payer",            "type": "address", "indexed": true  },
      { "name": "validator",        "type": "address", "indexed": true  },
      { "name": "feeAmount",        "type": "uint256", "indexed": false }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "ValidatorRegistered",
    "inputs": [
      { "name": "validator", "type": "address", "indexed": true  },
      { "name": "metaURI",   "type": "string",  "indexed": false }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "ValidatorDeregistered",
    "inputs": [
      { "name": "validator", "type": "address", "indexed": true }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "FeeScheduleSet",
    "inputs": [
      { "name": "verificationType", "type": "bytes32", "indexed": true  },
      { "name": "feeWei",           "type": "uint256", "indexed": false },
      { "name": "validator",        "type": "address", "indexed": true  }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "FeeScheduleDeactivated",
    "inputs": [
      { "name": "verificationType", "type": "bytes32", "indexed": true }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "Withdrawn",
    "inputs": [
      { "name": "validator", "type": "address", "indexed": true  },
      { "name": "amount",    "type": "uint256", "indexed": false }
    ],
    "anonymous": false
  },
  {
    "type": "event",
    "name": "OwnershipTransferred",
    "inputs": [
      { "name": "previousOwner", "type": "address", "indexed": true },
      { "name": "newOwner",      "type": "address", "indexed": true }
    ],
    "anonymous": false
  },
  { "type": "error", "name": "Unauthorized",                "inputs": [] },
  { "type": "error", "name": "ZeroAddress",                 "inputs": [] },
  { "type": "error", "name": "UnknownVerificationType",     "inputs": [{ "name": "verificationType", "type": "bytes32" }] },
  { "type": "error", "name": "InactiveVerificationType",    "inputs": [{ "name": "verificationType", "type": "bytes32" }] },
  { "type": "error", "name": "IncorrectFeeAmount",          "inputs": [{ "name": "expected", "type": "uint256" }, { "name": "received", "type": "uint256" }] },
  { "type": "error", "name": "ValidatorNotRegistered",      "inputs": [{ "name": "validator", "type": "address" }] },
  { "type": "error", "name": "NothingToWithdraw",           "inputs": [] },
  { "type": "error", "name": "TransferFailed",              "inputs": [] }
]
