{
  "$schema": "urn:ssid:registry:admin_ui:v1",
  "registry_type": "admin_ui_components",
  "version": "1.0.0",
  "created": "2026-03-28T00:00:00Z",
  "description": "UI component registry for the SSID Admin Dashboard. Tracks all frontend modules, themes, and design tokens.",
  "stack": {
    "framework": "React",
    "language": "TypeScript",
    "styling": "TailwindCSS",
    "build_tool": "vite",
    "port": 3000
  },
  "themes": [
    {
      "id": "ssid-light",
      "name": "SSID Light",
      "description": "Default light theme with SSID brand colors",
      "token_file": "src/themes/ssid-light.css"
    },
    {
      "id": "ssid-dark",
      "name": "SSID Dark",
      "description": "Dark theme for low-light environments",
      "token_file": "src/themes/ssid-dark.css"
    },
    {
      "id": "ssid-high-contrast",
      "name": "SSID High Contrast",
      "description": "WCAG AAA compliant high contrast theme",
      "token_file": "src/themes/ssid-high-contrast.css"
    },
    {
      "id": "ssid-audit",
      "name": "SSID Audit Mode",
      "description": "Stripped-down theme for audit and compliance review sessions",
      "token_file": "src/themes/ssid-audit.css"
    }
  ],
  "components": {
    "layout": {
      "AppShell": { "path": "src/components/layout/AppShell.tsx", "sha256": "PENDING_BUILD_HASH" },
      "Sidebar": { "path": "src/components/layout/Sidebar.tsx", "sha256": "PENDING_BUILD_HASH" },
      "TopNav": { "path": "src/components/layout/TopNav.tsx", "sha256": "PENDING_BUILD_HASH" },
      "Footer": { "path": "src/components/layout/Footer.tsx", "sha256": "PENDING_BUILD_HASH" }
    },
    "dashboard": {
      "HealthPanel": { "path": "src/components/dashboard/HealthPanel.tsx", "sha256": "PENDING_BUILD_HASH" },
      "MetricsGrid": { "path": "src/components/dashboard/MetricsGrid.tsx", "sha256": "PENDING_BUILD_HASH" },
      "ScoreCard": { "path": "src/components/dashboard/ScoreCard.tsx", "sha256": "PENDING_BUILD_HASH" },
      "ActivityFeed": { "path": "src/components/dashboard/ActivityFeed.tsx", "sha256": "PENDING_BUILD_HASH" }
    },
    "audit": {
      "EvidenceTable": { "path": "src/components/audit/EvidenceTable.tsx", "sha256": "PENDING_BUILD_HASH" },
      "AuditTimeline": { "path": "src/components/audit/AuditTimeline.tsx", "sha256": "PENDING_BUILD_HASH" },
      "HashVerifier": { "path": "src/components/audit/HashVerifier.tsx", "sha256": "PENDING_BUILD_HASH" }
    },
    "identity": {
      "ScoreOverview": { "path": "src/components/identity/ScoreOverview.tsx", "sha256": "PENDING_BUILD_HASH" },
      "SessionList": { "path": "src/components/identity/SessionList.tsx", "sha256": "PENDING_BUILD_HASH" },
      "DIDViewer": { "path": "src/components/identity/DIDViewer.tsx", "sha256": "PENDING_BUILD_HASH" }
    },
    "shared": {
      "Button": { "path": "src/components/shared/Button.tsx", "sha256": "PENDING_BUILD_HASH" },
      "Modal": { "path": "src/components/shared/Modal.tsx", "sha256": "PENDING_BUILD_HASH" },
      "DataTable": { "path": "src/components/shared/DataTable.tsx", "sha256": "PENDING_BUILD_HASH" },
      "StatusBadge": { "path": "src/components/shared/StatusBadge.tsx", "sha256": "PENDING_BUILD_HASH" },
      "ThemeToggle": { "path": "src/components/shared/ThemeToggle.tsx", "sha256": "PENDING_BUILD_HASH" }
    }
  },
  "design_tokens": {
    "colors": {
      "primary": "var(--ssid-color-primary)",
      "secondary": "var(--ssid-color-secondary)",
      "success": "var(--ssid-color-success)",
      "warning": "var(--ssid-color-warning)",
      "error": "var(--ssid-color-error)",
      "background": "var(--ssid-color-bg)",
      "surface": "var(--ssid-color-surface)",
      "text_primary": "var(--ssid-color-text-primary)",
      "text_secondary": "var(--ssid-color-text-secondary)"
    },
    "spacing": {
      "unit": "4px",
      "scale": [0, 1, 2, 3, 4, 6, 8, 12, 16, 24, 32]
    },
    "typography": {
      "font_family": "'Inter', system-ui, sans-serif",
      "font_mono": "'JetBrains Mono', monospace",
      "sizes": { "xs": "0.75rem", "sm": "0.875rem", "base": "1rem", "lg": "1.125rem", "xl": "1.25rem", "2xl": "1.5rem" }
    },
    "radii": { "sm": "4px", "md": "8px", "lg": "12px", "full": "9999px" },
    "shadows": {
      "sm": "0 1px 2px rgba(0,0,0,0.05)",
      "md": "0 4px 6px rgba(0,0,0,0.07)",
      "lg": "0 10px 15px rgba(0,0,0,0.1)"
    }
  }
}
